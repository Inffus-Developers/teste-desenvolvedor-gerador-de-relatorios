                },
                {
                  "key": "sort_dir",
                  "value": "desc"
                }
              ]
            },
            "description": "Download CSV imediato (stream). Mesmos filtros do relatório JSON."
          },
          "response": []
        },
        {
          "name": "Export PDF (sync)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/pdf"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/reports/billing/export/pdf?sort_by=due_date&sort_dir=desc",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "reports",
                "billing",
                "export",
                "pdf"
              ],
              "query": [
                {
                  "key": "date_from",
                  "value": "2026-01-01",
                  "disabled": true
                },
                {
                  "key": "date_to",
                  "value": "2026-12-31",
                  "disabled": true
                },
                {
                  "key": "status",
                  "value": "overdue",
                  "disabled": true
                },
                {
                  "key": "sort_by",
                  "value": "due_date"
                },
                {
                  "key": "sort_dir",
                  "value": "desc"
                }
              ]
            },
            "description": "Download PDF imediato. Limite de 2.000 linhas."
          },
          "response": []
        },
        {
          "name": "Queue Export (async)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 202) {",
                  "    const id = pm.response.json().data.id;",
                  "    pm.collectionVariables.set('exportId', id);",
                  "    pm.environment.set('exportId', id);",
                  "    pm.test('Export enfileirada', function () {",
                  "        pm.expect(id).to.be.a('string').and.not.empty;",
                  "    });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"format\": \"csv\",\n  \"status\": \"overdue\",\n  \"sort_by\": \"due_date\",\n  \"sort_dir\": \"desc\"\n}"
            },
            "url": "{{baseUrl}}/reports/billing/exports",
            "description": "Enfileira exportação via RabbitMQ. Requer `report-worker` ativo. Retorna 202."
          },
          "response": []
        },
        {
          "name": "Get Export Status",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const status = pm.response.json().data.status;",
                  "    pm.test('Status válido', function () {",
                  "        pm.expect(['pending', 'processing', 'completed', 'failed']).to.include(status);",
                  "    });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/reports/billing/exports/{{exportId}}",
            "description": "Polling de status: pending → processing → completed | failed."
          },
          "response": []
        },
        {
          "name": "Download Export (async)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "*/*"
              }
            ],
            "url": "{{baseUrl}}/reports/billing/exports/{{exportId}}/download",
            "description": "Download do arquivo gerado. Disponível apenas quando status = completed."
          },
          "response": []
        }
      ],
      "description": "Relatório de faturamento: consulta JSON, exportação síncrona e assíncrona."
